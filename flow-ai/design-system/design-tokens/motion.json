{
  "$schema": "Flow AI Design System — Motion Tokens v1",
  "$source": "Flow AI Design System",

  "duration": {
    "instant":  0,
    "fast":    100,
    "normal":  150,
    "slow":    250,
    "slower":  350,
    "slowest": 500
  },

  "easing": {
    "linear":       "linear",
    "ease":         "ease",
    "ease-in":      "cubic-bezier(0.4, 0, 1, 1)",
    "ease-out":     "cubic-bezier(0, 0, 0.2, 1)",
    "ease-in-out":  "cubic-bezier(0.4, 0, 0.2, 1)",
    "spring":       "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "bounce":       "cubic-bezier(0.68, -0.55, 0.27, 1.55)"
  },

  "transition": {
    "none":    "none",
    "all":     "all 150ms cubic-bezier(0, 0, 0.2, 1)",
    "colors":  "color 150ms cubic-bezier(0, 0, 0.2, 1), background-color 150ms cubic-bezier(0, 0, 0.2, 1), border-color 150ms cubic-bezier(0, 0, 0.2, 1)",
    "opacity": "opacity 150ms cubic-bezier(0, 0, 0.2, 1)",
    "shadow":  "box-shadow 150ms cubic-bezier(0, 0, 0.2, 1)",
    "transform": "transform 150ms cubic-bezier(0, 0, 0.2, 1)"
  },

  "animation": {
    "spin":        "spin 1s linear infinite",
    "ping":        "ping 1s cubic-bezier(0, 0, 0.2, 1) infinite",
    "pulse":       "pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite",
    "bounce":      "bounce 1s infinite",
    "fade-in":     "fadeIn 150ms cubic-bezier(0, 0, 0.2, 1)",
    "fade-out":    "fadeOut 150ms cubic-bezier(0.4, 0, 1, 1)",
    "slide-up":    "slideUp 250ms cubic-bezier(0.34, 1.56, 0.64, 1)",
    "slide-down":  "slideDown 250ms cubic-bezier(0.34, 1.56, 0.64, 1)",
    "scale-in":    "scaleIn 150ms cubic-bezier(0.34, 1.56, 0.64, 1)",
    "scale-out":   "scaleOut 100ms cubic-bezier(0.4, 0, 1, 1)",
    "shimmer":     "shimmer 1.5s ease-in-out infinite"
  },

  "$componentUsage": {
    "button-hover":    { "duration": "fast",   "easing": "ease-out",    "properties": ["colors", "shadow", "transform"] },
    "modal-open":      { "duration": "normal", "easing": "spring",      "properties": ["opacity", "transform"] },
    "modal-close":     { "duration": "fast",   "easing": "ease-in",     "properties": ["opacity", "transform"] },
    "dropdown-open":   { "duration": "normal", "easing": "ease-out",    "properties": ["opacity", "transform"] },
    "toast-enter":     { "duration": "normal", "easing": "spring",      "properties": ["opacity", "transform"] },
    "toast-exit":      { "duration": "fast",   "easing": "ease-in",     "properties": ["opacity", "transform"] },
    "tooltip-show":    { "duration": "fast",   "easing": "ease-out",    "properties": ["opacity"] },
    "sidebar-toggle":  { "duration": "slow",   "easing": "ease-in-out", "properties": ["transform", "opacity"] },
    "skeleton":        { "duration": "slowest","easing": "ease-in-out", "properties": ["opacity"] }
  }
}
